# MapForge environment variables.
#
# This file is COMMITTED as a documented template. To override locally, copy it
# to `.env.local` (git-ignored). Never commit real secrets.
#
# Only variables prefixed with VITE_ are exposed to the browser.

# Application display name (shown in the browser tab).
VITE_APP_NAME="MapForge"

# Default MapLibre camera (decimal degrees + zoom).
VITE_DEFAULT_MAP_CENTER_LAT=30.0
VITE_DEFAULT_MAP_CENTER_LON=70.0
VITE_DEFAULT_MAP_ZOOM=4

# Optional: a self-hosted MapLibre style.json URL (air-gapped / rate-sensitive
# deployments). When unset, MapForge uses the public OpenFreeMap Liberty style.
# VITE_MAPLIBRE_STYLE_URL=

# Optional: Google raster tile template for the Google basemaps (satellite /
# hybrid / roadmap / terrain). {s}=subdomain (mt0-3), {lyrs}=layer type,
# {x}/{y}/{z}=tile coords. Defaults to the value below.
#
# ⚠️  mt*.google.com/vt is an UNOFFICIAL, undocumented endpoint — no SLA, against
# Google's ToS, may break/rate-limit. SANDBOX / local-dev use only. For
# production use the keyed Google Map Tiles API
# (https://developers.google.com/maps/documentation/tile). The registry also
# ships a key-less "Esri World Imagery" satellite basemap as a legit alternative.
# VITE_GOOGLE_TILES_TEMPLATE="https://mt{s}.google.com/vt/lyrs={lyrs}&x={x}&y={y}&z={z}"

# ─────────────────────────────────────────────────────────────────────────────
# Local / LAN tiles (your own tile server). Each is OPTIONAL and only shows up
# when set. Use standard XYZ templates: {z}/{x}/{y}. Configured layers appear
# under a separate "Local" group in the basemap dropdown.
#
# Gotchas:
#  - URL-encode spaces as %20 (e.g. a TileServer-GL style id "OSM OpenMapTiles"
#    becomes "OSM%20OpenMapTiles"). A literal space is an invalid URL.
#  - tileSize: imagery/elevation are treated as 256px; OSM/Hybrid are treated as
#    512px (the "/512/" path) — wired in code, not here.
# ─────────────────────────────────────────────────────────────────────────────

# Locally-hosted aerial/satellite imagery (raster XYZ).
# VITE_LOCAL_IMAGERY="http://10.0.0.1:9080/imagery/{z}/{x}/{y}.jpg"

# Locally-hosted OSM street basemap (raster XYZ, 512px TileServer-GL style).
# VITE_LOCAL_OSM="http://10.0.0.1:8089/styles/OSM%20OpenMapTiles/512/{z}/{x}/{y}.png"

# Locally-hosted hybrid (imagery + labels) tiles (raster XYZ, 512px).
# VITE_LOCAL_HYBRID="http://10.0.0.1:8088/styles/OSM%20OpenMapTiles/512/{z}/{x}/{y}.png"

# Locally-hosted DEM (elevation) tiles for 3D terrain (raster-dem XYZ). When set,
# a "3D Terrain" toggle appears, plus a raw-tile "Local Elevation (raw tiles)"
# preview entry in the dropdown so you can confirm the tiles serve.
# VITE_LOCAL_ELEVATION="http://10.0.0.1:9080/elevation/{z}/{x}/{y}.png"

# Elevation RGB→height encoding: "terrarium" (default) or "mapbox". Wrong value
# makes terrain look spiky/inverted.
# VITE_LOCAL_ELEVATION_ENCODING="terrarium"

# Optional max zoom for the local tile sets above. Default: 19. Lower this if
# your server has fewer zoom levels (otherwise high-zoom tiles 404).
# VITE_LOCAL_TILES_MAX_ZOOM=19
